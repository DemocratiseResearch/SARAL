# ── Firebase ──────────────────────────────────────────────────────────
# Base64-encoded Firebase service account JSON.
# To encode: base64 -i path/to/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_BASE64=""

# ── LLM Provider (via LiteLLM) ───────────────────────────────────────
# Format: "provider/model" — e.g. gemini/gemini-2.0-flash, gpt-4o-mini,
# anthropic/claude-3-haiku-20240307, groq/llama3-8b-8192, ollama/llama3
# Full list: https://docs.litellm.ai/docs/providers
LLM_MODEL="gemini/gemini-2.0-flash"

# Server-level default API key for the LLM provider above.
# Users can also store their own keys (encrypted) via the UI.
# Set the env var that matches your provider:
#   OpenAI   → OPENAI_API_KEY
#   Gemini   → GEMINI_API_KEY
#   Anthropic → ANTHROPIC_API_KEY
#   Groq     → GROQ_API_KEY
# Or set LLM_API_KEY as a generic fallback.
OPENAI_API_KEY=""

# ── Sarvam AI (Indian-language TTS) ──────────────────────────────────
SARVAM_API_KEY=""

# ── Encryption ───────────────────────────────────────────────────────
# Fernet key used to encrypt user API keys at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=""

# ── Database ─────────────────────────────────────────────────────────
# PostgreSQL (recommended):
#   DATABASE_URL=postgresql://username:password@localhost:5432/saral
# If left empty, defaults to postgresql://localhost:5432/saral
DATABASE_URL=

# ── CORS ─────────────────────────────────────────────────────────────
# JSON array of allowed origins. Update for production.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── General ──────────────────────────────────────────────────────────
DEBUG="false"
LOG_LEVEL="info"
